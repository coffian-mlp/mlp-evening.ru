# === MLP-Evening .htaccess ===

# 0. Кодировка UTF-8
AddDefaultCharset UTF-8

# 1. Обработка ошибок
ErrorDocument 404 /404.php

# 2. Безопасность: Запрещаем листинг директорий (чтобы не видели список файлов)
Options -Indexes

# 3. Базовая защита конфигов (на всякий случай, если Apache не настроен скрывать их)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# 4. Безопасность: непубличные пути закрыты от прямого доступа из браузера (2026-07-16).
#    Раньше migrations/*.sql отдавались сырым текстом (утечка схемы), а tests/*.php
#    исполнялись через веб. Ассеты компонентов (/src/.../*.js|*.css) остаются доступны.

# 4.1 Служебные каталоги без публичных ресурсов — целиком 403.
RedirectMatch 403 (?i)^/(migrations|tests|scripts|dev_knowledge|docs|logs|cache)(/|$)

# 4.2 В /src/ наружу нужны только ассеты компонентов; исходники PHP — закрыть.
RedirectMatch 403 (?i)^/src/.*\.(php|inc|sql|md)$

# 4.3 CLI-скрипты в корне запускаются только из командной строки.
<FilesMatch "^(migrate|bot_worker|cron_llm)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 4.4 Сырые файлы данных/дампы в корне — не для веба.
<FilesMatch "\.(sql|log|md|sample)$">
    Order allow,deny
    Deny from all
</FilesMatch>

