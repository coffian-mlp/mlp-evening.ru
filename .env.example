# Конфигурация окружения MLP-Evening (MLP-252).
# Скопируй в .env и заполни. Файл .env НЕ коммитится (секреты).
# Читают: PHP (Infra\Env) и docker-compose (нативная интерполяция ${...}).

# --- База данных ---
# Docker-контур: host 'db' (имя сервиса); прод: обычно 'localhost'.
DB_HOST=db
DB_NAME=coffian_eplist
DB_USER=coffian_eplist
DB_PASS=change_me_please
DB_CHARSET=utf8mb4

# Пароль root для контейнера MySQL (только docker, PHP его не читает).
DB_ROOT_PASS=change_me_root

# --- Чат ---
# 'sse' — из коробки; 'centrifugo' — рекомендуется для больших залов.
CHAT_DRIVER=sse
CENTRIFUGO_API_URL=http://127.0.0.1:8000/api
# Пустой ключ = realtime-publish отключён (тестовый контур).
CENTRIFUGO_API_KEY=
CENTRIFUGO_SECRET=
